NEXT_PUBLIC_AGORA_APP_ID=
NEXT_AGORA_APP_CERTIFICATE=
NEXT_PUBLIC_AGENT_UID=123456
NEXT_AGENT_GREETING=Hi there! I am your Agora x Gemma voice coach.

# Local Gemma / LM Studio
# For LM Studio, use the local server port shown in the app, for example 12345.
GEMMA_BASE_URL=http://localhost:12345
# LM Studio chat endpoint used by the Next.js proxy route.
GEMMA_CHAT_URL=http://localhost:12345/api/v1/chat
# Use the exact model identifier shown in LM Studio, such as google/gemma-4-e2b.
GEMMA_MODEL=google/gemma-4-e2b
GEMMA_TIMEOUT_MS=30000
GEMMA_API_KEY=local-gemma
# Optional public OpenAI-compatible URL for the live Agora agent.
# Point this at a public URL for your Next.js proxy route, not the raw model server.
# Example if you tunnel the Next.js app:
# ngrok http 3000
# GEMMA_PUBLIC_CHAT_URL=https://your-ngrok-domain.ngrok-free.dev/api/chat/completions
GEMMA_PUBLIC_CHAT_URL=
